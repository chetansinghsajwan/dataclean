{
  "packages": [
    "git@latest",
    "gh@latest",
    "ruff@latest",
    "uv@latest",
    "go-task@latest",
    "jdk17@latest",
    "python@3.12"
  ],
  "env": {
    "PYTHONPATH": "$PWD/src",
    "JAVA_HOME": "$DEVBOX_PACKAGES_DIR/zulu17"
  },
  "shell": {
    "aliases": {
      "task": "go-task"
    },
    "init_hook": [
      "unset JAVA_HOME",
      "task setup"
    ]
  }
}
