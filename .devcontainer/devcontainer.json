{
    "name": "dataclean",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu26.04",
    "containerEnv": {
        "PYTHONPATH": "${containerWorkspaceFolder}/src",
        "UV_PYTHON": "3.12"
    },
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/github-cli:": {},
        "ghcr.io/jsburckhardt/devcontainer-features/ruff:1": {},
        "ghcr.io/devcontainer-community/devcontainer-features/astral.sh-uv:1": {
            "version": "latest",
            "shellautocompletion": true
        },
        "ghcr.io/audacioustux/devcontainers/taskfile:1": {},
        "ghcr.io/devcontainers/features/java:1": {
            "version": "lts",
            "jdkDistro": "open"
        },
        "ghcr.io/aqua/devcontainer-antigravity-cli/antigravity-cli:1": {}
    },
    "postCreateCommand": "uv sync",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff"
            ],
            "settings": {
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff",
                    "editor.formatOnSave": true,
                    "editor.codeActionsOnSave": {

                        // Auto-sorts & cleans imports on save
                        "source.organizeImports": "always",

                        // Auto-fixes lint violations (like removing unused imports)
                        "source.fixAll": "always"
                    }
                }
            }
        }
    }
}
